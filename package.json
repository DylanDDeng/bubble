{
  "name": "bubble",
  "version": "0.1.0",
  "description": "A terminal coding agent",
  "type": "module",
  "bin": {
    "bubble": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/main.js",
    "dev": "tsc && bun dist/main.js",
    "start": "bun dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opentui/core": "^0.1.99",
    "@opentui/solid": "^0.1.99",
    "chalk": "^5.3.0",
    "diff": "^7.0.0",
    "openai": "^4.77.0",
    "opentui-spinner": "^0.0.6",
    "picomatch": "^4.0.4",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
